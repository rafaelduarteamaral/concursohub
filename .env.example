# ============================================================
# ConcursoHub — Environment Variables Example
# Copy to .env and fill in your values
# ============================================================

# --- Database ---
DB_HOST=localhost
DB_PORT=5433
DB_USER=concursohub
DB_PASSWORD=changeme
DB_NAME=concursohub
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# --- Redis ---
REDIS_URL=redis://localhost:6380

# --- API (internal, server-side) ---
API_URL=http://api:3001

# --- API (public, browser-side) ---
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Next.js App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production-use-openssl-rand-base64-32

# --- Admin credentials ---
ADMIN_EMAIL=admin@concursohub.com.br
ADMIN_PASSWORD=changeme

# --- ISR Revalidation ---
REVALIDATE_SECRET=change-me-in-production

# --- AI Provider ---
# Options: ollama | anthropic | openai
AI_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- AI Cost Guard ---
MAX_DAILY_AI_COST_USD=5.0

# --- Sentry (optional) ---
SENTRY_DSN=

# --- Scraper ---
DEFAULT_CRAWL_INTERVAL_MINUTES=60
SCRAPER_POLL_INTERVAL=60

# --- OAuth (optional) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
